# ========================================
# DOCKERFILE CLIENT - DOCKER DEV
# ========================================

# Build stage
FROM node:20-alpine AS builder

WORKDIR /app
RUN npm install -g pnpm

# Copier les fichiers communs (requis pour @common/*)
COPY common ./common
COPY client/package.json client/pnpm-lock.yaml ./client/

WORKDIR /app/client
RUN pnpm install --frozen-lockfile

WORKDIR /app
COPY client ./client

WORKDIR /app/client

# Build en mode DOCKER (utilise environment.docker.ts avec port 5000)
RUN pnpm ng build --configuration docker

# Dependencies stage
FROM node:20-alpine AS deps

WORKDIR /app
RUN npm install serve

# Production stage (distroless pour sécurité)
FROM gcr.io/distroless/nodejs20-debian12

WORKDIR /app

COPY --from=deps /app/node_modules ./node_modules
COPY --from=builder /app/client/dist/client ./dist

EXPOSE 80

# distroless n'a ni shell ni wget/curl : le check passe par node -e directement.
HEALTHCHECK --interval=15s --timeout=5s --start-period=20s --retries=5 \
    CMD ["node", "-e", "require('http').get({host:'127.0.0.1',port:80,path:'/',timeout:3000},r=>process.exit(r.statusCode===200?0:1)).on('error',()=>process.exit(1))"]

# Serve en mode SPA (-s redirige toutes les routes vers index.html)
CMD ["node_modules/serve/build/main.js", "-s", "dist", "-l", "80"]
