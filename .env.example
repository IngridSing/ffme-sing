# ========================================
# Variables pour docker-compose.dev.yml
# Copier vers .env : cp .env.example .env
# ========================================

# MongoDB (conteneur docker)
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=admin123
MONGO_URI=mongodb://admin:admin123@mongodb:27017/FFME?authSource=admin
DB_URL=mongodb://admin:admin123@mongodb:27017/FFME?authSource=admin

# Auth API
JWT_SECRET=dev-secret-change-me

# Premier compte superadmin, cree automatiquement au demarrage s'il n'existe pas encore
# (laisser vide pour desactiver la creation automatique)
DEFAULT_ADMIN_EMAIL=
DEFAULT_ADMIN_PASSWORD=

# Email (optionnel en local)
MAIL_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Stockage images local — dossier uploads/ à la racine (monté dans Docker via ./uploads:/app/uploads)
UPLOADS_DIR=/app/uploads

# URLs publiques (Docker dev : API sur 5000, client sur 4200)
SERVER_URL=http://localhost:5001/
CLIENT_URL=http://localhost:4200/

# Singpay (optionnel en local)
SINGPAY_CLIENT_ID=
SINGPAY_CLIENT_SECRET=
SINGPAY_WALLET_ID=
SINGPAY_DISBURSEMENT_ID=

# Migration one-shot SFTP → uploads (script migrate-sftp-to-local.ts uniquement, pas utilisé au runtime)
# FTP_HOST=
# FTP_PORT=22
# FTP_USER=
# FTP_PASSWORD=
