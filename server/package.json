{
    "name": "server",
    "description": "Serveur du projet de base pour le cours de LOG2990",
    "version": "1.3.0",
    "private": true,
    "scripts": {
        "start": "nodemon",
        "build": "rimraf out && tsc --project tsconfig.app.json && npm run build:swagger",
    "build:swagger": "ts-node scripts/generate-swagger.ts",
        "format": "prettier --config ../.prettierrc.yaml --write \"app/**/*\"",
        "lint": "eslint -c .eslintrc.json \"./app/**/*.ts\" --format stylish",
        "lint:fix": "npm run lint -- --fix",
        "test": "cross-env TS_NODE_PROJECT='./tsconfig.spec.json' mocha --config=.mocharc.json --node-env=test",
        "coverage": "cross-env TS_NODE_PROJECT='./tsconfig.spec.json' nyc mocha --config=.mocharc.json --node-env=test --exit"
    },
    "nyc": {
        "check-coverage": true,
        "branches": 80,
        "lines": 80,
        "functions": 80,
        "statements": 80,
        "per-file": true,
        "include": [
            "app/**/*.ts"
        ],
        "extension": [
            ".ts"
        ],
        "exclude": [
            "**/*.spec.ts",
            "app/index.ts",
            "app/server.ts",
            "app/app.ts"
        ],
        "require": [
            "ts-node/register",
            "tsconfig-paths/register"
        ],
        "reporter": [
            "html",
            "text"
        ],
        "all": true,
        "cache": true,
        "sourceMap": true,
        "instrument": true
    },
    "_moduleAliases": {
        "@app": "out/server/app",
        "@common": "out/common"
    },
    "dependencies": {
        "axios": "^1.13.2",
        "bcrypt": "^6.0.0",
        "cookie-parser": "1.4.7",
        "cors": "2.8.6",
        "dotenv": "^17.2.3",
        "express": "5.2.1",
        "express-rate-limit": "^8.2.1",
        "http-status-codes": "2.3.0",
        "jsonwebtoken": "^9.0.3",
        "mime-types": "^3.0.2",
        "module-alias": "2.2.3",
        "mongodb": "7.0.0",
        "mongoose": "^9.1.5",
        "multer": "^2.0.2",
        "nodemailer": "^7.0.12",
        "p-limit": "^7.2.0",
        "prettier": "3.8.1",
        "reflect-metadata": "0.2.2",
        "serve-favicon": "2.5.1",
        "sharp": "^0.34.5",
        "swagger-jsdoc": "6.2.8",
        "swagger-ui-express": "5.0.1",
        "typedi": "0.10.0",
        "uuid": "^13.0.0",
        "zod": "^4.3.5"
    },
    "devDependencies": {
        "@types/axios": "^0.14.4",
        "@types/bcrypt": "^6.0.0",
        "@types/body-parser": "1.19.6",
        "@types/chai": "5.2.3",
        "@types/cookie-parser": "1.4.10",
        "@types/cors": "2.8.19",
        "@types/express": "^5.0.6",
        "@types/express-rate-limit": "^6.0.2",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/mime-types": "^3.0.1",
        "@types/mocha": "10.0.10",
        "@types/mongoose": "^5.11.97",
        "@types/multer": "^2.0.0",
        "@types/node": "^25.0.10",
        "@types/node-uuid": "0.0.32",
        "@types/nodemailer": "^7.0.5",
        "@types/sharp": "^0.32.0",
        "@types/sinon": "21.0.0",
        "@types/supertest": "6.0.3",
        "@types/swagger-jsdoc": "6.0.4",
        "@types/swagger-ui-express": "4.1.8",
        "@types/uuid": "^11.0.0",
        "@typescript-eslint/eslint-plugin": "8.53.1",
        "@typescript-eslint/parser": "8.53.1",
        "chai": "6.2.2",
        "cross-env": "10.1.0",
        "crypto": "^1.0.1",
        "eslint": "9.39.2",
        "eslint-config-prettier": "10.1.8",
        "eslint-import-resolver-typescript": "4.4.4",
        "eslint-plugin-import": "2.32.0",
        "eslint-plugin-jsdoc": "62.3.0",
        "eslint-plugin-prettier": "5.5.5",
        "mocha": "11.7.5",
        "moose": "^0.0.3",
        "nodemon": "3.1.11",
        "nyc": "17.1.0",
        "rimraf": "6.1.2",
        "sinon": "21.0.1",
        "source-map-support": "0.5.21",
        "ssh2-sftp-client": "^12.0.1",
        "supertest": "7.2.2",
        "ts-node": "10.9.2",
        "tsconfig-paths": "4.2.0",
        "typescript": "5.9.3"
    }
}
